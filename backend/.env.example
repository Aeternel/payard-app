# Django
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=replace-with-at-least-50-random-characters
FIELD_ENCRYPTION_KEY=replace-with-a-fernet-key
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8001
CORS_ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL, Redis, and RabbitMQ service names match compose.yaml.
DATABASE_URL=postgresql://payyard:payyard_dev_password@db:5432/payyard
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://payyard:payyard_dev_password@rabbitmq:5672/payyard

# Public URL of the separately hosted Next.js worker portal.
WORKER_PORTAL_URL=http://localhost:3000/worker

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# WhatsApp Cloud API
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# SMS provider hook
SMS_PROVIDER=console
SMS_API_URL=
SMS_API_KEY=

# Optional private object storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=me-central-1
